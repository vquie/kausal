{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    "schedule:weekdays",
    ":noUnscheduledUpdates",
    "mergeConfidence:all-badges",
    ":disableMajorUpdates"
  ],
  "semanticCommits": "enabled",
  "vulnerabilityAlerts": {
    "addLabels": [
      "security"
    ]
  },
  "dependencyDashboardOSVVulnerabilitySummary": "all"
}
